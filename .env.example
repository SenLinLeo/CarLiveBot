# 方舟大模型（火山引擎）
ARK_API_KEY=your_ark_api_key_here
ARK_CHAT_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_MODEL_ID=doubao-seed-2-0-lite-260215

# 火山引擎 TTS V3
TTS_APP_ID=your_tts_appid
TTS_ACCESS_TOKEN=your_tts_access_token
